# Copy this file to .env and fill in your own values. Never commit .env.
#
# Your shop subdomain. Either "my-store" or "my-store.myshopify.com" works.
SHOPIFY_SHOP=your-store

# Custom app Admin API access token. Placeholder only — replace with your own.
# Real Shopify tokens start with "shpat_". The value below is NOT a real token.
SHOPIFY_ADMIN_API_TOKEN=shpat_xxx_placeholder

# Optional. Admin API version. Default is the latest stable; override only if
# you know what you are doing. Format: YYYY-MM.
# 2026-04 = latest stable (default). 2026-07 = release candidate (not for prod).
SHOPIFY_API_VERSION=2026-04

# Optional. Backoff tuning.
SHOPIFY_MAX_RETRIES=5
SHOPIFY_TIMEOUT_SECONDS=30
